# Copy to ~/.config/reachy/env (chmod 600). Real values live there — never committed.
# All mac/ scripts + the SwiftBar plugin source this file automatically.
ROBOT_IP=10.0.0.20        # your Reachy Mini's LAN IP
ROBOT_USER=pollen         # default SSH user on Reachy Mini Wireless
ROBOT_PASS=change-me      # Pollen's factory default is "root" — CHANGE IT on the robot
DONGLE_CARD=Audio_1       # ALSA card id of the USB DAC (if you added an external speaker)
