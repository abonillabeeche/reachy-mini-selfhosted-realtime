#!/usr/bin/env bash
[ -f "$HOME/.config/reachy/env" ] && . "$HOME/.config/reachy/env"
# reachy — subcommand dispatcher for the local Reachy Mini helpers.
#
# Usage:
#   reachy wake              # bring her up (motors, slow head lift, start app)
#   reachy sleep             # fold down (stop app, motors off)
#   reachy listen            # live-stream Reachy's mic to this Mac (Ctrl-C to stop)
#   reachy see               # wake + live-view Reachy's camera on this Mac (Ctrl-C to stop)
#   reachy say "hello!"      # speak arbitrary text through Reachy's speaker
#   reachy status            # print motors + head pose + running app
#   reachy volume 80         # set external-speaker (DAC) volume (0-100)
#   reachy mute              # DAC volume 0
#   reachy unmute            # DAC volume 60
#   reachy mic on|off|toggle # push-to-talk: gate the mic (stops speaker feedback)
#   reachy talk [secs]       # timed push-to-talk: mic on for N s, then auto-off
set -euo pipefail

: "${ROBOT_IP:=10.0.0.20}"
: "${ROBOT_USER:=pollen}"
: "${ROBOT_PASS:=}"
# Output now goes through the USB DAC dongle (ALSA card id "Audio_1") into an
# external speaker. Volume controls target that card, not the daemon's built-in.
: "${DONGLE_CARD:=Audio_1}"
BASE="http://${ROBOT_IP}:8000"
HERE="$(cd "$(dirname "$(readlink "$0" || echo "$0")")" && pwd)"

rssh() { sshpass -p "$ROBOT_PASS" ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=8 "${ROBOT_USER}@${ROBOT_IP}" "$@"; }

usage() {
  sed -n '3,15p' "$0" | sed 's/^# \{0,1\}//'
  exit 2
}

case "${1:-}" in
  wake)   exec "${HERE}/reachy-wake.sh" ;;
  sleep)  exec "${HERE}/reachy-sleep.sh" ;;
  listen) exec "${HERE}/reachy-listen.sh" ;;
  see)    exec "${HERE}/reachy-see.sh" ;;
  say)
    shift
    [ $# -eq 0 ] && { echo "usage: reachy say \"text\""; exit 2; }
    exec "${HERE}/say-reachy.sh" "$@"
    ;;
  say-prompt)
    # AppleScript dialog for the SwiftBar menu item.
    text=$(osascript -e 'try
      text returned of (display dialog "Say what to Reachy?" default answer "" with title "Reachy — Say" buttons {"Cancel","Speak"} default button "Speak")
    on error
      return ""
    end try' 2>/dev/null || true)
    [ -z "$text" ] && exit 0
    exec "${HERE}/say-reachy.sh" "$text"
    ;;
  status)
    pitch=$(curl -sS --max-time 5 "${BASE}/api/state/present_head_pose" | \
      python3 -c "import sys,json,math; d=json.load(sys.stdin); print(round(math.degrees(d['pitch']),1))")
    mode=$(curl -sS --max-time 5 "${BASE}/api/motors/status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('mode',''))")
    vol=$(rssh "amixer -c ${DONGLE_CARD} sget PCM 2>/dev/null | grep -oE '[0-9]+%' | head -1" 2>/dev/null)
    app=$(curl -sS --max-time 5 "${BASE}/api/apps/current-app-status" | \
      python3 -c "import sys,json; d=json.load(sys.stdin); print((d or {}).get('info',{}).get('name') or '<none>', '(' + ((d or {}).get('state') or '') + ')')")
    echo "Reachy @ ${ROBOT_IP}"
    echo "  head:      pitch=${pitch}°"
    echo "  motors:    ${mode}"
    echo "  spk (DAC): ${vol:-?}   (external speaker path)"
    echo "  app:       ${app}"
    ;;
  volume)
    lvl="${2:-}"
    [ -z "$lvl" ] && { echo "usage: reachy volume <0-100>  (DAC digital level into the external speaker)"; exit 2; }
    rssh "amixer -c ${DONGLE_CARD} sset PCM ${lvl}% >/dev/null 2>&1 && sudo alsactl store >/dev/null 2>&1; amixer -c ${DONGLE_CARD} sget PCM | grep -oE '[0-9]+%' | head -1"
    ;;
  mute)
    rssh "amixer -c ${DONGLE_CARD} sset PCM 0% >/dev/null 2>&1; echo muted"
    ;;
  unmute)
    rssh "amixer -c ${DONGLE_CARD} sset PCM 60% >/dev/null 2>&1; echo 'unmuted (60%)'"
    ;;
  mic)
    # Push-to-talk gate: mutes/unmutes the XMOS mic capture (card 0) so Reachy
    # doesn't hear its own voice from the external speaker (feedback).
    case "${2:-status}" in
      on)   rssh "amixer -c 0 sset Headset,0 cap >/dev/null 2>&1; amixer -c 0 sset Headset,1 cap >/dev/null 2>&1; echo 'mic ON (listening)'" ;;
      off)  rssh "amixer -c 0 sset Headset,0 nocap >/dev/null 2>&1; amixer -c 0 sset Headset,1 nocap >/dev/null 2>&1; echo 'mic OFF'" ;;
      toggle)
        st=$(rssh "amixer -c 0 sget Headset,0 2>/dev/null | grep -oE '\[on\]|\[off\]' | head -1")
        if [ "$st" = "[on]" ]; then
          rssh "amixer -c 0 sset Headset,0 nocap >/dev/null 2>&1; amixer -c 0 sset Headset,1 nocap >/dev/null 2>&1; echo 'mic OFF'"
        else
          rssh "amixer -c 0 sset Headset,0 cap >/dev/null 2>&1; amixer -c 0 sset Headset,1 cap >/dev/null 2>&1; echo 'mic ON (listening)'"
        fi ;;
      status)
        st=$(rssh "amixer -c 0 sget Headset,0 2>/dev/null | grep -oE '\[on\]|\[off\]' | head -1")
        [ "$st" = "[on]" ] && echo "on" || echo "off" ;;
      *) echo "usage: reachy mic {on|off|toggle|status}"; exit 2 ;;
    esac
    ;;
  profile)
    APPDIR=/venvs/apps_venv/lib/python3.12/site-packages/reachy_mini_conversation_app
    PROFDIR=/venvs/apps_venv/lib/python3.12/site-packages/reachy_talk_data/profiles
    name="${2:-}"
    if [ -z "$name" ]; then
      # list available + current
      cur=$(rssh "grep -oE '\"profile\": *\"[^\"]*\"' $APPDIR/startup_settings.json 2>/dev/null | sed -E 's/.*\"([^\"]*)\"$/\1/'")
      echo "current: ${cur:-default}"
      echo "available:"
      rssh "ls -1 $PROFDIR 2>/dev/null | grep -vE '__pycache__'" | sed 's/^/  /'
      exit 0
    fi
    echo "switching to profile: $name"
    rssh "sudo sed -i 's/REACHY_MINI_CUSTOM_PROFILE=[a-zA-Z0-9_-]*/REACHY_MINI_CUSTOM_PROFILE=${name}/' /etc/systemd/system/reachy-mini-daemon.service.d/hf-realtime.conf 2>/dev/null; \
          sudo sed -i 's/REACHY_MINI_CUSTOM_PROFILE=[a-zA-Z0-9_-]*/REACHY_MINI_CUSTOM_PROFILE=${name}/' $APPDIR/.env 2>/dev/null; \
          v=\$(grep -oE '\"voice\": *\"[^\"]*\"' $APPDIR/startup_settings.json 2>/dev/null | sed -E 's/.*\"([^\"]*)\"\$/\1/'); v=\${v:-af_nova}; \
          echo \"{\\\"profile\\\": \\\"${name}\\\", \\\"voice\\\": \\\"\$v\\\"}\" | sudo tee $APPDIR/startup_settings.json >/dev/null; \
          sudo systemctl daemon-reload"
    curl -sS --max-time 15 -X POST "${BASE}/api/apps/restart-current-app" >/dev/null 2>&1
    sleep 12
    # restart resets DAC + we keep mic muted for push-to-talk
    rssh "amixer -c ${DONGLE_CARD} sset PCM 90% >/dev/null 2>&1; amixer -c 0 sset Headset,0 nocap >/dev/null 2>&1; amixer -c 0 sset Headset,1 nocap >/dev/null 2>&1" 2>/dev/null
    echo "switched to '${name}' (app restarted, DAC 90%, mic muted for PTT)"
    ;;
  talk)
    # Timed push-to-talk: unmute, let you speak, auto-mute after N seconds
    # (default 12) so Reachy replies to the speaker without hearing itself.
    secs="${2:-4}"
    rssh "amixer -c 0 sset Headset,0 cap >/dev/null 2>&1; amixer -c 0 sset Headset,1 cap >/dev/null 2>&1"
    echo "🎙  mic ON — speak now (${secs}s)…"
    sleep "$secs"
    rssh "amixer -c 0 sset Headset,0 nocap >/dev/null 2>&1; amixer -c 0 sset Headset,1 nocap >/dev/null 2>&1"
    echo "mic OFF — Reachy will reply."
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown subcommand: $1"
    echo
    usage
    ;;
esac
