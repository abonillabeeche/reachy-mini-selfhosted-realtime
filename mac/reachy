#!/usr/bin/env bash
# reachy — subcommand dispatcher for the local Reachy Mini helpers.
#
# Usage:
#   reachy wake              # bring her up (motors, slow head lift, start app)
#   reachy sleep             # fold down (stop app, motors off)
#   reachy say "hello!"      # speak arbitrary text through Reachy's speaker
#   reachy status            # print motors + head pose + running app
#   reachy volume 80         # set speaker volume (0-100)
#   reachy mute              # volume 0
#   reachy unmute            # volume 100
set -euo pipefail

: "${ROBOT_IP:=10.0.0.154}"
BASE="http://${ROBOT_IP}:8000"
HERE="$(cd "$(dirname "$(readlink "$0" || echo "$0")")" && pwd)"

usage() {
  sed -n '3,15p' "$0" | sed 's/^# \{0,1\}//'
  exit 2
}

case "${1:-}" in
  wake)   exec "${HERE}/reachy-wake.sh" ;;
  sleep)  exec "${HERE}/reachy-sleep.sh" ;;
  say)
    shift
    [ $# -eq 0 ] && { echo "usage: reachy say \"text\""; exit 2; }
    exec "${HERE}/say-reachy.sh" "$@"
    ;;
  say-prompt)
    # AppleScript dialog for the SwiftBar menu item.
    text=$(osascript -e 'try
      text returned of (display dialog "Say what to Reachy?" default answer "" with title "Reachy — Say" buttons {"Cancel","Speak"} default button "Speak")
    on error
      return ""
    end try' 2>/dev/null || true)
    [ -z "$text" ] && exit 0
    exec "${HERE}/say-reachy.sh" "$text"
    ;;
  status)
    pitch=$(curl -sS --max-time 5 "${BASE}/api/state/present_head_pose" | \
      python3 -c "import sys,json,math; d=json.load(sys.stdin); print(round(math.degrees(d['pitch']),1))")
    mode=$(curl -sS --max-time 5 "${BASE}/api/motors/status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('mode',''))")
    vol=$(curl -sS --max-time 5 "${BASE}/api/volume/current" | python3 -c "import sys,json; print(json.load(sys.stdin).get('volume',''))")
    app=$(curl -sS --max-time 5 "${BASE}/api/apps/current-app-status" | \
      python3 -c "import sys,json; d=json.load(sys.stdin); print((d or {}).get('info',{}).get('name') or '<none>', '(' + ((d or {}).get('state') or '') + ')')")
    echo "Reachy @ ${ROBOT_IP}"
    echo "  head:   pitch=${pitch}°"
    echo "  motors: ${mode}"
    echo "  volume: ${vol}%"
    echo "  app:    ${app}"
    ;;
  volume)
    lvl="${2:-}"
    [ -z "$lvl" ] && { echo "usage: reachy volume <0-100>"; exit 2; }
    curl -sS --max-time 5 -X POST "${BASE}/api/volume/set" \
      -H "Content-Type: application/json" -d "{\"volume\":${lvl}}"
    echo
    ;;
  mute)
    curl -sS --max-time 5 -X POST "${BASE}/api/volume/set" \
      -H "Content-Type: application/json" -d '{"volume":0}'
    echo
    ;;
  unmute)
    curl -sS --max-time 5 -X POST "${BASE}/api/volume/set" \
      -H "Content-Type: application/json" -d '{"volume":100}'
    echo
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown subcommand: $1"
    echo
    usage
    ;;
esac
