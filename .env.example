# Copy to .env and edit. Consumed by helper scripts and by manifest envsubst.
# Nothing here is committed — .env is git-ignored.

# --- Cluster / GPU node ---
# LAN IP of the node running Ollama + the reachy-s2s pod (the DGX Spark, Jetson,
# or similar single-GPU box).
NODE_IP=10.0.0.10

# --- Robot ---
# LAN IP of the Reachy Mini Wireless (find via router / mDNS `reachy-mini.local`).
ROBOT_IP=10.0.0.20
# SSH user on the robot (Pollen Robotics default is `pollen`).
ROBOT_USER=pollen
# The robot's default SSH password is documented at
# https://huggingface.co/docs/reachy_mini/platforms/reachy_mini/ — CHANGE IT.
ROBOT_PASS=change-me

# --- LLMs (routed via cluster-internal Ollama) ---
# Kubernetes DNS name of the Ollama service; the s2s pod resolves this internally.
OLLAMA_INTERNAL_URL=http://ollama.ollama.svc.cluster.local:11434/v1
# Public NodePort form of the same service; the robot's camera tool uses this.
OLLAMA_NODEPORT_URL=http://${NODE_IP}:31434/v1

# Chat LLM (must support OpenAI tool calling; VLMs generally do NOT).
CHAT_MODEL=llama3.1:8b
# Vision LLM (used only by the camera tool for image Q&A).
VISION_MODEL=qwen2.5vl:7b

# --- s2s NodePort exposure ---
# Port the WebSocket realtime endpoint is exposed on (pod listens on 8765).
S2S_NODEPORT=31765
